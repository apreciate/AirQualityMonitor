# Doxygen configuration for AirQualityMonitor
# Generated by CMake — edytuj Doxyfile.in, nie Doxyfile

PROJECT_NAME           = "Monitor Jakości Powietrza"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Aplikacja do monitorowania jakości powietrza w Polsce (GIOŚ API)"

OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs
INPUT                  = @CMAKE_SOURCE_DIR@/src
RECURSIVE              = YES

# Język
OUTPUT_LANGUAGE        = Polish

# Co generować
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# Wygląd HTML
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# Wykresy (wymaga graphviz)
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
UML_LOOK               = YES
DOT_GRAPH_MAX_NODES    = 50

# Co dokumentować
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
SHOW_INCLUDE_FILES     = YES

# Ostrzeżenia
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

# Rozszerzenia plików
FILE_PATTERNS          = *.h *.cpp

# Styl komentarzy
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES

# Aliasy skrótów
ALIASES               += "note=\note"
ALIASES               += "warning=\warning"
ALIASES               += "pattern=\par Wzorzec projektowy:\n"
